# Copy to .env and fill in. Secrets live here only — never commit .env.
# (bootstrap creates .env from this file automatically.)

# --- Camera (RTSP) ---
# Hikvision example: Channels/101 = main stream, 102 = sub-stream.
RTSP_URL=rtsp://USER:PASS@192.168.1.64:554/Streaming/Channels/101
CAMERA_ID=hikvision_01

# --- MQTT (Home Assistant) ---
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_PREFIX=frigate

# --- Model ---
# Pose model file or path; extra weights can live in models/ (n/s/m).
MODEL_PATH=yolo11n-pose.pt
